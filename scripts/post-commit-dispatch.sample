#!/usr/bin/env bash
set -euo pipefail

# Prefer reference-transaction-dispatch.sample for normal use. This simpler
# hook only sees commits made in the current checked-out worktree.
required_host="${AGENT_DISPATCH_HOST:-theserver}"
current_host="$(hostname -s 2>/dev/null || hostname)"
[[ "$current_host" == "$required_host" ]] || exit 0

dispatcher="${AGENT_DISPATCHER:-/home/name/learnings/scripts/dispatch-agent.sh}"
[[ -x "$dispatcher" ]] || exit 0
command -v tmux >/dev/null 2>&1 || exit 0

msg="$(git log -1 --format=%B HEAD)"
grep -Eqi '(^|[[:space:]])(@no-dispatch|\[no-dispatch\])([[:space:][:punct:]]|$)' <<<"$msg" && exit 0
grep -Eqi '(^|[[:space:]])@(codex|claude)([[:space:][:punct:]]|$)' <<<"$msg" || exit 0

repo="${AGENT_DISPATCH_REPO:-$(git rev-parse --show-toplevel)}"
branch="$(git branch --show-current)"
sha="$(git rev-parse HEAD)"
session="${AGENT_DISPATCH_TMUX_SESSION:-agent-dispatch}"
log_dir="${AGENT_DISPATCH_LOG_DIR:-/home/name/agent-dispatch-logs}"
mkdir -p "$log_dir"

tmux has-session -t "$session" 2>/dev/null || tmux new-session -d -s "$session" -c "$repo"
log_file="$log_dir/dispatch-${branch//\//-}-${sha:0:12}.log"
cmd="$(printf 'AGENT_DISPATCH_LOG_DIR=%q %q %q %q %q >> %q 2>&1' "$log_dir" "$dispatcher" "$repo" "$sha" "$branch" "$log_file")"
tmux new-window -d -t "$session:" -n "dispatch-${sha:0:7}" "$cmd"
